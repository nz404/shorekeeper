# ══════════════════════════════════════════════
# SHOREKEEPER — Environment Variables
# Salin file ini ke .env dan isi nilainya.
# ══════════════════════════════════════════════

# ─────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
MY_CHAT_ID=your_telegram_chat_id_here
ADMIN_NAME=Irvan

# ─────────────────────────────────────────────
# AI — Groq
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# DATABASE — MariaDB / MySQL
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=shorekeeper_db


# ─────────────────────────────────────────────
# WEB DASHBOARD
# ─────────────────────────────────────────────
WEB_PORT=3000

# Kredensial admin dashboard (WAJIB diganti!)
WEB_ADMIN_USER=admin
WEB_PASSWORD=ganti_password_kuat_di_sini

# Kredensial akun demo/guest (bisa dinonaktifkan)
WEB_GUEST_USER=demo
WEB_GUEST_PASSWORD=demo
WEB_GUEST_LIMIT=5

# ─────────────────────────────────────────────
# MONITOR SERVER
# ─────────────────────────────────────────────
MONITOR_CPU_THRESHOLD=80
MONITOR_RAM_THRESHOLD=85
MONITOR_DISK_THRESHOLD=90
MONITOR_INTERVAL_MS=300000

# ─────────────────────────────────────────────
# SSH
# ─────────────────────────────────────────────
# Timeout sesi idle SSH (ms) — default 5 menit
SSH_SESSION_TIMEOUT_MS=300000
# Timeout command biasa (ms) — default 30 detik
SSH_CMD_TIMEOUT_MS=30000
# Timeout command panjang seperti apt/npm (ms) — default 10 menit
SSH_LONG_TIMEOUT_MS=600000

# ─────────────────────────────────────────────
# TIMEZONE
# ─────────────────────────────────────────────
TIMEZONE=Asia/Jakarta
